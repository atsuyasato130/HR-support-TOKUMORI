# ============================================================
# Tokumori Business Platform (TBP) — .gitignore
# GitHub にアップロードしてはならないファイル
# ============================================================

# 🚨 聖域: privateディレクトリ
/private/

# 環境変数・認証情報
.env
.env.*
.env.local
.env.production
.env.development
**/credentials.json
**/client_secret*.json
**/token.json
**/processed_email_ids.json

# 実行ログ
*.log
logs/
**/logs/

# データベース
*.db
*.sqlite
*.sqlite3

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# Node / Next.js
node_modules/
.next/
.vercel/
*.tsbuildinfo

# macOS
.DS_Store
.AppleDouble

# IDE
.vscode/
.idea/

# 一時ファイル
_tmp_rename/
*.removed

# hr_support は独立リポ (hr-support-bot) として管理
agents/hr_support/
