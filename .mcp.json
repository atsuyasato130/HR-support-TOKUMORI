{
  "mcpServers": {
    "hr-support": {
      "command": "python3",
      "args": [
        "agents/hr_support/integrations/mcp_salesforce_notion.py"
      ]
    },
    "salesforce-dx": {
      "command": "npx",
      "args": [
        "-y",
        "@salesforce/mcp",
        "--orgs", "prod",
        "--toolsets", "orgs,data",
        "--allow-non-ga-tools"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
