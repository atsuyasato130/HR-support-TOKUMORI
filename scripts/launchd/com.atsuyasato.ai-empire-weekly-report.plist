<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.atsuyasato.ai-empire-weekly-report</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/atsuyasato/Claude AI/ai-empire/scripts/daily_patrol.py</string>
    <string>--task</string>
    <string>weekly_report</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/atsuyasato/Claude AI/ai-empire</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/atsuyasato/Claude AI/ai-empire/agents/logs/weekly-report.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/atsuyasato/Claude AI/ai-empire/agents/logs/weekly-report-error.log</string>

  <key>RunAtLoad</key>
  <false/>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
</dict>
</plist>
