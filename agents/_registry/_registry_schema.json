{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hr-agent-registry-schema",
  "title": "HR Agent Registry Schema",
  "description": "100+ Agent Governance — エージェントレジストリのJSONSchemaバリデーション定義",
  "type": "object",
  "required": ["version", "updated", "agents"],
  "properties": {
    "version":     {"type": "string"},
    "updated":     {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "description": {"type": "string"},
    "naming_rule": {"type": "string"},
    "domains":     {"type": "object"},
    "roles":       {"type": "object"},
    "agents": {
      "type": "array",
      "items": {"$ref": "#/definitions/Agent"},
      "minItems": 1
    }
  },
  "definitions": {
    "Agent": {
      "type": "object",
      "required": ["id", "domain", "role", "target", "canonical_name", "legacy_module",
                   "description", "input", "output", "dependencies", "llm_required", "status", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z]+_[a-z]+_[a-z0-9_]+$",
          "description": "[Domain]_[Role]_[Target] 形式の一意ID（スネークケース）"
        },
        "domain": {
          "type": "string",
          "enum": ["hr"],
          "description": "事業ドメイン。新ドメイン追加時はdomains辞書も更新"
        },
        "role": {
          "type": "string",
          "enum": ["watcher", "parser", "processor", "executor", "orchestrator"],
          "description": "Micro-Workers の5ロール"
        },
        "target": {
          "type": "string",
          "description": "処理対象リソース名（スネークケース）"
        },
        "canonical_name": {
          "type": "string",
          "pattern": "^[a-z]+_[a-z]+_[a-z0-9_]+$",
          "description": "公式名称 = id と同値"
        },
        "legacy_module": {
          "type": "string",
          "description": "現在の物理ファイルパス（career_advisor/ 相対）"
        },
        "description": {
          "type": "string",
          "maxLength": 200
        },
        "input": {
          "type": "object",
          "required": ["type", "source"],
          "properties": {
            "type":   {"type": "string", "enum": ["none", "state_file", "user_message", "api_read", "text", "file"]},
            "source": {"type": "string"},
            "path":   {"type": "string"},
            "schema": {"type": "string"}
          }
        },
        "output": {
          "type": "object",
          "required": ["type", "destination"],
          "properties": {
            "type":        {"type": "string", "enum": ["state_file", "text", "api_write", "file", "multiple"]},
            "destination": {"type": "string"},
            "path":        {"type": "string"},
            "schema":      {"type": "string"}
          }
        },
        "dependencies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "使用する外部API・サービス識別子"
        },
        "llm_required": {
          "type": "boolean",
          "description": "LLM（Claude）呼び出しが必須かどうか"
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "draft", "disabled"]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    }
  }
}
