{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agent_config_schema",
  "title": "TemplateAgent設定スキーマ",
  "description": "agent_configs/*.json の共通バリデーションスキーマ。_から始まるファイルはスキャン対象外。",
  "type": "object",

  "required": ["agent_key", "agent_name", "interaction_mode"],

  "properties": {
    "agent_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "英小文字・数字・アンダースコアのみ。AGENT_REGISTRYキーと重複不可"
    },
    "agent_name": {
      "type": "string",
      "description": "表示名（日本語可）"
    },
    "description": {
      "type": "string",
      "description": "1行説明"
    },
    "interaction_mode": {
      "type": "string",
      "enum": ["chat", "one_shot", "form_then_generate", "menu"],
      "description": "動作モード"
    },
    "model": {
      "type": "string",
      "default": "claude-sonnet-4-6"
    },
    "max_tokens": {
      "type": "integer",
      "default": 2048,
      "minimum": 100,
      "maximum": 8096
    },
    "stream": {
      "type": "boolean",
      "default": true,
      "description": "chatモード時のストリーミング表示"
    },
    "system_prompt": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["template"],
          "properties": {
            "template": {
              "type": "string",
              "description": "{{変数名}}形式のテンプレート。domain_hr.jsonの変数は自動注入"
            },
            "variables": {
              "type": "object",
              "description": "静的変数。domain_hr.jsonの値より高優先度"
            }
          }
        }
      ]
    },
    "opening_message": {
      "type": "string",
      "description": "chatモード開始時のAI発言"
    },
    "input_prompt": {
      "type": "string",
      "description": "one_shotモードの入力プロンプト文字列",
      "default": "入力 > "
    },
    "multiline_input": {
      "type": "boolean",
      "default": false,
      "description": "one_shotモードで複数行入力を使うか"
    },
    "form_fields": {
      "type": "array",
      "description": "form_then_generateモード用フォーム定義",
      "items": {
        "type": "object",
        "required": ["key", "prompt"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "prompt": { "type": "string" },
          "required": { "type": "boolean", "default": false },
          "default": {},
          "multiline": { "type": "boolean", "default": false }
        }
      }
    },
    "generation_prompt_template": {
      "type": "string",
      "description": "form_then_generateモードでClaudeに送るプロンプトテンプレート。{{フィールドkey}}で置換される"
    },
    "menu": {
      "type": "object",
      "description": "menuモード設定",
      "properties": {
        "title": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "label", "mode"],
            "properties": {
              "key": { "type": "string" },
              "label": { "type": "string" },
              "mode": { "type": "string", "enum": ["chat", "one_shot", "form_then_generate"] },
              "opening_message": { "type": "string" },
              "form_fields": { "type": "array" },
              "generation_prompt_template": { "type": "string" },
              "system_prompt": {}
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "clipboard_copy": { "type": "boolean", "default": false },
        "save_to_file": { "type": "boolean", "default": false },
        "file_pattern": { "type": "string", "default": "{date}_{agent_key}_output.txt" },
        "display_separator": { "type": "boolean", "default": true }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "keywords": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "integer", "default": 5 }
      }
    },
    "domain_config_path": {
      "type": "string",
      "default": "config/domain_hr.json",
      "description": "業界転用用ドメイン設定。config/domain_realestate.json等に変更可"
    },
    "version": { "type": "string" },
    "created": { "type": "string" },
    "author": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": {
      "type": "string",
      "enum": ["active", "draft", "deprecated"],
      "default": "active"
    }
  }
}
