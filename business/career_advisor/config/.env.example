# Anthropic API Key
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Slack Bot Token (xoxb- で始まる)
# 取得先: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...

# Slack App-Level Token (xapp- で始まる、Socket Mode に必要)
# 取得先: https://api.slack.com/apps → Basic Information → App-Level Tokens
# スコープ: connections:write
SLACK_APP_TOKEN=xapp-...
