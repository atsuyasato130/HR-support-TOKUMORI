{
  "_comment": "HRドメイン設定ファイル。ビジネスロジック（workflow engine）から分離されたドメイン固有情報。別業界（不動産・コンサル等）に転用する場合はこのファイルを差し替えるだけでよい。",

  "domain": "hr",
  "domain_name": "HR人材支援",
  "version": "1.0",

  "entity": {
    "label": "学生",
    "label_en": "student",
    "counterpart_label": "企業",
    "session_label": "面談",
    "advisor_label": "CA"
  },

  "extraction": {
    "system_prompt_hint": "新卒・中途就職支援の面談議事録から学生情報を抽出する。就活軸・ガクチカ・希望業界・選考状況などHR固有の情報に注目する。",
    "key_fields": [
      "student_name", "university", "faculty", "graduation_year",
      "career_axis", "gauchika", "desired_industry", "desired_occupation",
      "current_companies", "meeting_summary", "next_actions", "advisor_name", "meeting_date"
    ]
  },

  "crm": {
    "platform": "salesforce",
    "object_type": "Account",
    "search_by": "full_name",
    "new_record_fixed_fields": {
      "Status__pc": "支援中",
      "Phase__pc": "初回面談済",
      "CS_keiyu__c": "なし",
      "Field27__c": "直紹介対象",
      "OfficialLineRegistration__pc": true,
      "RecordTypeId": "0122w000001Ry2hAAC"
    },
    "task_subject_prefix_new": "面談",
    "task_subject_prefix_returning": "2回目面談"
  },

  "communication": {
    "channel": "LINE",
    "style": "friendly_formal_japanese",
    "no_emoji": true,
    "post_meeting_template_hints": [
      "お疲れさまの言葉から始める",
      "面談で確認した次のステップを自然に伝える",
      "「何かあればいつでも連絡ください」という一文を添える",
      "200文字以下の段落に分ける"
    ],
    "placeholder_format": "[  ]"
  },

  "report": {
    "format": "post_meeting_6section",
    "save_dir": "career_advisor/reports",
    "filename_pattern": "{date}_{name}_所感.txt",
    "sections": [
      "基本情報",
      "第一印象・コミュニケーション",
      "就活状況・志望軸",
      "強み・懸念点",
      "CAコメント・支援方針",
      "次のアクション"
    ]
  },

  "notification": {
    "platform": "slack",
    "enabled": true,
    "target": "student_thread",
    "search_channels": ["C0A2YSANGKS", "C0A4SJDDUV9"],
    "thread_marker": "📍",
    "message_template": "面談完了: {date} / {advisor} / 次: {next_actions_summary}",
    "post_on_dry_run": false
  },

  "workflow": {
    "steps": [
      "extract",
      "enrich",
      "crm_write",
      "communication_draft",
      "report_generate",
      "slack_notify"
    ],
    "abort_on_extract_failure": true,
    "continue_on_step_failure": true
  },

  "portability_notes": {
    "real_estate": "entity.label='顧客', crm.object_type='Opportunity', communication.channel='メール', notification.search_channels=[]",
    "consulting": "entity.label='クライアント', crm.object_type='Account', report.sections=['課題整理','提案方針','次回アジェンダ']",
    "how_to_switch": "このファイルを domain_realestate.json 等に差し替えて PostInterviewFullSupportAgent の DOMAIN_CONFIG_PATH を変更するだけで別業界で動作する"
  }
}
